{
  "name": "partyplug",
  "version": "0.1.0",
  "description": "Reusable framework for shared-screen + phone-controller party games: transport (relay/WebRTC) plus a headless room/lobby/host state machine.",
  "type": "commonjs",
  "exports": {
    "./RoomFlow": { "types": "./RoomFlow.d.ts", "default": "./RoomFlow.js" },
    "./PartyConnection": { "types": "./PartyConnection.d.ts", "default": "./PartyConnection.js" },
    "./PartyFastlane": { "types": "./PartyFastlane.d.ts", "default": "./PartyFastlane.js" }
  },
  "files": [
    "*.js",
    "*.d.ts",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js"
  },
  "sideEffects": [
    "PartyConnection.js",
    "PartyFastlane.js",
    "RoomFlow.js"
  ]
}
