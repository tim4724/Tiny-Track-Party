{
  "name": "tiny-track-party",
  "version": "0.1.0",
  "description": "Browser-based multiplayer toy-car racing with phone tilt controllers",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node --test tests/*.test.js partyplug/tests/*.test.js",
    "gen:schematics": "node scripts/gen-track-schematics.js",
    "measure": "node scripts/measure-kit.js \"$KIT/Models/GLB format\"",
    "artwork": "node scripts/capture-artwork.js",
    "icon:item": "node scripts/capture-item-icon.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "three": "^0.184.0",
    "ws": "^8.21.0"
  }
}
